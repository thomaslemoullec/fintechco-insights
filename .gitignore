# --- Internal presenter materials — never commit ---
_internal/
*.zip

# --- Claude Code project-local (personal, not shared) ---
.claude/settings.local.json

# --- Python ---
.venv/
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/

# --- Runtime artifacts ---
audit.log

# --- Local secrets — never commit (secrets live in Secret Manager) ---
.env
*.env

# --- Terraform local state ---
infra/terraform/.terraform/
*.tfstate
*.tfstate.*
.terraform.lock.hcl

# NOTE: services/insights/app/data/*.csv are cached FRED series data and ARE committed
# (public economic data, no real or personal data). scripts/gen_fixtures.py is the
# offline synthetic fallback if the cache is ever missing.
